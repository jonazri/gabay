#!/bin/bash
# akiflow — Dispatcher for Akiflow CLI commands inside agent containers.
# Sources the function library and dispatches subcommands.
# Usage: akiflow <subcommand> [args...]

FUNCTIONS_FILE="/home/node/.claude/skills/akiflow/akiflow-functions.sh"

if [[ ! -f "$FUNCTIONS_FILE" ]]; then
  echo "Error: akiflow functions not found at $FUNCTIONS_FILE" >&2
  exit 1
fi

source "$FUNCTIONS_FILE"

if [[ $# -eq 0 || "$1" == "help" || "$1" == "--help" || "$1" == "-h" ]]; then
  echo "akiflow — Manage tasks, events, and calendar via local SQLite"
  echo ""
  echo "Usage: akiflow <command> [args...]"
  echo ""
  echo "Commands:"
  declare -F | grep -oP 'akiflow:\K.*' | grep -v '^_' | sort | sed 's/^/  /'
  exit 0
fi

cmd="akiflow:$1"
shift

if declare -f "$cmd" > /dev/null 2>&1; then
  "$cmd" "$@"
else
  echo "Error: unknown command '$cmd'" >&2
  echo "Run 'akiflow help' for available commands." >&2
  exit 1
fi
