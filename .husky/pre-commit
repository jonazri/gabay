# Auto-format staged TypeScript files and re-stage so the commit includes fixes
STAGED_TS="$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' | tr '\n' ' ')"
if [ -n "$STAGED_TS" ]; then
  npx prettier --write $STAGED_TS
  echo "$STAGED_TS" | xargs git add
fi

# Warn if src/ differs from upstream (catches accidental commits of applied state)
if git remote get-url upstream >/dev/null 2>&1; then
  if ! git diff --quiet upstream/main -- src/ 2>/dev/null; then
    echo ""
    echo "WARNING: src/ differs from upstream/main."
    echo "If you're committing skill files, this is expected during development."
    echo "Run 'npm run clean-skills' before committing if src/ should be clean."
    echo ""
  fi
fi
